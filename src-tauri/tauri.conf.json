{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ReadMarkdown",
  "version": "0.1.0",
  "identifier": "sh.readmarkdown.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ReadMarkdown",
        "width": 1120,
        "height": 740,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Read Markdown files in any folder.",
    "longDescription": "ReadMarkdown is a focused Markdown reader for macOS. Pick a folder and browse every Markdown file inside, recursively, in a calm reading view."
  }
}
